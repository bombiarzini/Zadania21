<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie21_2.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="40,0"
            Spacing="30">

            <Label
                Text="Zaloguj sie"
                FontSize="32"
                HorizontalOptions="Center" />
            <Entry
                Keyboard="Email"
                x:Name="EmailEntry"
                TextChanged="Entry_TextChanged"
                
            />
            <Entry
                IsPassword="True"
                x:Name="PasswordEntry"
                TextChanged="Entry_TextChanged"
            />
            <Button
                Text="Zaloguj"
                HorizontalOptions="Center"
                Clicked="OnButtonClicked"
                IsVisible="False"
                x:Name="LoginButton"
                />
            

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
